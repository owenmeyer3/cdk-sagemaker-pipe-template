{
    "End": True,
    "Type": "Task",
    "Resource": "arn:aws:states:::sagemaker:createTransformJob",
    "Parameters": {
        "TransformJobName.$": "States.Format("abalone-bl-transform-job-{}", $$.Execution.Name)",
        "ModelName.$": "$.GetOrCreateModelTask.MODEL_NAME",
        "ModelClientConfig": {
            "InvocationsMaxRetries": 3,
            "InvocationsTimeoutInSeconds": 300
        },
        "TransformInput": {
            "DataSource": {
                "S3DataSource": {
                    "S3Uri.$": "$.PrepBaselineSetsTask.BASELINE_X_FILE",
                    "S3DataType": "S3Prefix"
                }
            },
            "ContentType": "text/csv",
            "SplitType": "Line"
        },
        "TransformOutput": {
            "S3OutputPath": "s3://omm-test-bucket/pipelines/abalone/baseline"
        },
        "TransformResources": {
            "InstanceCount": 1,
            "InstanceType.$": "$.TRANSFORM_INSTANCE_TYPE"
        }
    },
    "ResultPath": "$.BaselineTransformTask"
}