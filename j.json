                  "schedule_expression.$": "$.MONITOR_SCHEDULE_EXPRESSION",
                  "data_analysis_start_time.$": "$.MONITOR_ANALYSIS_START_TIME",
                  "data_analysis_end_time.$": "$.MONITOR_ANALYSIS_END_TIME"
                }
              }
